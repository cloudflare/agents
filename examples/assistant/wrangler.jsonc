{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "ai": { "binding": "AI", "remote": true },
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    // OAuth and chat routes are handled by the Worker. The nested
    // agent routes under /agents/* stay on the default routing path.
    "run_worker_first": ["/agents/*", "/auth/*", "/chat", "/chat/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyAssistant",
        "name": "MyAssistant"
      }
    ]
  },
  "worker_loaders": [{ "binding": "LOADER" }],
  "main": "src/server.ts",
  "migrations": [
    {
      "new_sqlite_classes": ["MyAssistant"],
      "tag": "v1"
    }
  ],
  "name": "assistant-example",
  "secrets": {
    "required": ["GITHUB_CLIENT_ID", "GITHUB_CLIENT_SECRET"]
  }
}
