{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "ai": { "binding": "AI", "remote": true },
  // Date is after the 2026-03-15 Cloudflare runtime change that
  // populates `ctx.id.name` inside alarm handlers. Pre-this date,
  // alarms fire without name propagation, which trips PartyServer's
  // `this.name` getter when a wake path goes through alarm() instead
  // of fetch() with idFromName(). Symptom is
  // "Error in Assistant:<unnamed> fetch: … this.ctx.id.name is not set".
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*"]
  },
  "durable_objects": {
    "bindings": [
      // Only `Assistant` is bound top-level. `Researcher` is addressed
      // as a facet of an Assistant (`/agents/assistant/{id}/sub/researcher/...`)
      // and doesn't need its own binding — only a `new_sqlite_classes` entry.
      { "class_name": "Assistant", "name": "Assistant" }
    ]
  },
  "main": "src/server.ts",
  "migrations": [
    {
      "new_sqlite_classes": ["Assistant", "Researcher", "Planner"],
      "tag": "v1"
    }
  ],
  "name": "agents-as-tools-example"
}
