{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "ai": { "binding": "AI", "remote": true },
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*"]
  },
  "durable_objects": {
    "bindings": [
      // Only `Assistant` is bound top-level. `Researcher` is addressed
      // as a facet of an Assistant (`/agents/assistant/{id}/sub/researcher/...`)
      // and doesn't need its own binding — only a `new_sqlite_classes` entry.
      { "class_name": "Assistant", "name": "Assistant" }
    ]
  },
  "main": "src/server.ts",
  "migrations": [
    {
      "new_sqlite_classes": ["Assistant", "Researcher"],
      "tag": "v1"
    }
  ],
  "name": "agents-as-tools-example"
}
