{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "ai": { "binding": "AI", "remote": true },
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 5
    }
  ],
  "assets": {
    "binding": "Assets",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/*"]
  },
  // Disable preview URLs — sandbox containers should not be publicly addressable
  "preview_urls": false,
  "durable_objects": {
    "bindings": [
      {
        "class_name": "SandboxChatAgent",
        "name": "SandboxChatAgent"
      },
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "main": "src/server.ts",
  "migrations": [
    {
      "new_sqlite_classes": ["SandboxChatAgent", "Sandbox"],
      "tag": "v1"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BACKUP_BUCKET",
      "bucket_name": "cloudflare-agents-example-opencode",
      "remote": true
    }
  ],
  "name": "agents-example-opencode"
}
