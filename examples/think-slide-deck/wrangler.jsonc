{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "think-slide-deck-example",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/preview/*"]
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SlideDeckAgent",
        "class_name": "SlideDeckAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SlideDeckAgent"]
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ]
}
