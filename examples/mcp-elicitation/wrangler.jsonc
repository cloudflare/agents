{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mcp-elicitation-legacy-demo",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "LegacyElicitationAgent",
        "class_name": "LegacyElicitationAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["LegacyElicitationAgent"]
    }
  ],
  "observability": {
    "logs": {
      "enabled": true
    }
  }
}
