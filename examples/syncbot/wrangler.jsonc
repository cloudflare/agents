{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "syncbot",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "SyncBot",
        "name": "SyncBot"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["SyncBot"],
      "tag": "v1"
    }
  ],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/slack/*", "/telegram/*"]
  },
  // Set via .env file or `wrangler secret put`
  "secrets": {
    "required": [
      // "SLACK_BOT_TOKEN",
      // "SLACK_SIGNING_SECRET",
      "TELEGRAM_BOT_TOKEN"
    ]
  }
}
