{
  "name": "chat-recovery-e2e-test",
  "main": "worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "ChatRecoveryTestAgent",
        "class_name": "ChatRecoveryTestAgent"
      },
      {
        "name": "ChatNoProgressExhaustAgent",
        "class_name": "ChatNoProgressExhaustAgent"
      },
      {
        "name": "ChatAbortedExhaustAgent",
        "class_name": "ChatAbortedExhaustAgent"
      },
      {
        "name": "ChatWorkBudgetExhaustAgent",
        "class_name": "ChatWorkBudgetExhaustAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRecoveryTestAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "ChatNoProgressExhaustAgent",
        "ChatAbortedExhaustAgent"
      ]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["ChatWorkBudgetExhaustAgent"]
    }
  ]
}
