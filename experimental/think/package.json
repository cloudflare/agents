{
  "name": "@cloudflare/agents-think",
  "description": "Experimental coding agent built on Workers + Durable Objects",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "test": "vitest run",
    "test:workers": "vitest run -c tests/vitest.config.ts",
    "test:node": "vitest run --project think-node",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/react": "^3.0.107",
    "@cloudflare/agents-ui": "*",
    "@cloudflare/kumo": "^1.9.0",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.0.2",
    "agents": "*",
    "ai": "^6.0.105",
    "just-bash": "^2.11.6",
    "streamdown": "^2.2.0",
    "workers-ai-provider": "^3.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "tailwindcss": "^4.2.1"
  }
}
