# Local development variables for `wrangler dev --local`.
#
# Copy this file to `.dev.vars` (gitignored) to enable it. `.dev.vars`
# is loaded automatically by wrangler dev and its values surface on
# `env` inside the Worker.
#
# LOCAL_DEV=1 flips on the dev-only HTTP surface in src/index.ts
# (gated on `env.LOCAL_DEV === "1"`):
#
#   POST /dev/dispatch          { repo, issueNumber, instruction?, installationToken? }
#                               -> 202 { session, threadUrl, submissionId }
#   GET  /dev/messages/:session -> the DO message log (agent.debugMessages())
#
# These routes let you drive the agent over plain HTTP against real
# containers without the production dispatch path. Never set this in
# production.
LOCAL_DEV=1
