# Local env — copy to `.env` (gitignored): cp .env_example .env
#
# Read by the e2e harness (tests-e2e/harness.ts), which loads it into the
# `wrangler dev --local` process, and by recent wrangler dev itself.
#
# GH_TOKEN: the token the local agent uses where prod uses a GitHub App
# installation token (gh auth inside the container). A fine-grained PAT with
# repo read is enough to reproduce; opening PRs needs contents + pull_requests
# write.
GH_TOKEN=
# LOCAL_DEV=1 unlocks the dev-only HTTP surface in src/index.ts:
#   POST /dev/dispatch          { repo, issueNumber, instruction?, installationToken? }
#   GET  /dev/messages/:session
# The e2e harness always sets this itself (--var LOCAL_DEV:1); it is here for
# hand-driven `wrangler dev` sessions. Never set in production.
LOCAL_DEV=1
