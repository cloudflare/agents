{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "agents/**/*.ts",
    "workflows/**/*.ts",
    ".flue/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
