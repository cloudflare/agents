{
  "name": "@automations/triage-agent",
  "description": "Flue agent that labels new Agents SDK issues using only existing repo labels",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "triage": "flue run triage --target node",
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "typecheck": "tsc --noEmit",
    "docs": "flue docs"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.9",
    "typescript": "^6.0.3"
  }
}
