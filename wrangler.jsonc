{
  "name": "repro-1938",
  "main": "src/server.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*"]
  },
  "durable_objects": {
    "bindings": [
      { "name": "ReproAgent", "class_name": "ReproAgent" },
      { "name": "McpCatalog", "class_name": "McpCatalog" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ReproAgent", "McpCatalog"] }
  ],
  "observability": { "enabled": true }
}
