{
  "name": "repro-1965-mcp-h2-stall",
  "main": "src/server.ts",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
