{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "rebuild-ported-test-worker",
  "main": "worker.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": [
    "nodejs_compat",
    "enable_nodejs_tty_module",
    "enable_nodejs_fs_module",
    "enable_nodejs_http_modules",
    "enable_nodejs_perf_hooks_module",
    "enable_nodejs_v8_module",
    "enable_nodejs_process_v2"
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "TestAssistantAgentAgent",
        "name": "TestAssistantAgentAgent"
      },
      {
        "class_name": "ThinkClientToolsAgent",
        "name": "ThinkClientToolsAgent"
      },
      {
        "class_name": "ThinkTestAgent",
        "name": "ThinkTestAgent"
      },
      {
        "class_name": "ThinkExecuteHitlAgent",
        "name": "ThinkExecuteHitlAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "TestAssistantAgentAgent",
        "ThinkClientToolsAgent",
        "ThinkTestAgent",
        "ThinkExecuteHitlAgent"
      ]
    }
  ]
}
