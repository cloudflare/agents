{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "rebuild-cloudflare-demo",
  "main": "worker.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "DemoAgentDO",
        "name": "DEMO_AGENT_DO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "DemoAgentDO"
      ]
    }
  ]
}
